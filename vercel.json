{
    "version": 2,
    "buildCommand": "bash vercel-build.sh",
    "outputDirectory": "public",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/admin/(.*)",
            "destination": "/admin/index.html"
        }
    ]
}